# OpenAI
OPENAI_API_KEY=<your_openai_api_key>
OPENAI_MODEL=gpt-4.1-mini

# Google
GOOGLE_PLACES_API_KEY=<your_google_places_api_key>

# MySQL (CISE hosting — mysql.cise.ufl.edu)
# For local dev: run `ssh -L 3307:mysql.cise.ufl.edu:3306 <cise-user>@rain.cise.ufl.edu -N`
# then use DB_HOST=127.0.0.1 and DB_PORT=3307 below
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=<your_cise_username>
DB_PASSWORD=<your_cise_db_password> # not gatorlink!
DB_NAME=travel_app

# JWT — used to sign/verify auth tokens
# Generate a strong secret: python3 -c "import secrets; print(secrets.token_hex(32))"
# Never share or commit the real value.
JWT_SECRET=<generate_a_long_random_secret>

# Email — set ONE of two paths below.
#
# Path A (recommended on hosts that block SMTP, like DigitalOcean droplets):
# Resend HTTP API — sign up at https://resend.com, get an API key (starts with "re_")
RESEND_API_KEY=<your_resend_api_key>
# Sender: verified domain address, or "onboarding@resend.dev" for initial testing
FROM_EMAIL=onboarding@resend.dev
#
# Path B (local dev; Gmail SMTP — blocked outbound on DO droplets):
# Enable 2FA on Google account, then generate an App Password:
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<your_gmail_address>
SMTP_PASSWORD=<your_gmail_app_password>

APP_URL=http://localhost:4200

# CORS — comma-separated list of allowed frontend origins
# Local dev: http://localhost:4200
# Production example: https://plancation.vercel.app
ALLOWED_ORIGINS=http://localhost:4200
